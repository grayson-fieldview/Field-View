# =============================================================================
# Field View — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Variables marked OPTIONAL fall back to sensible defaults or feature-flag off.
# Variables marked PLATFORM are set automatically by Replit/Vercel — do not set
# them yourself in local `.env` unless you are intentionally simulating that env.
# =============================================================================


# -----------------------------------------------------------------------------
# Database — REQUIRED
# -----------------------------------------------------------------------------
# Postgres connection string. In production this is AWS RDS; in dev it's Neon.
# RDS hosts auto-append `?sslmode=no-verify` in drizzle.config.ts.
DATABASE_URL=postgresql://user:password@host:5432/fieldview


# -----------------------------------------------------------------------------
# Session — REQUIRED
# -----------------------------------------------------------------------------
# Used to sign session cookies. Must be long, random, and stable across
# deploys (rotating it logs everyone out).
# Generate with: openssl rand -base64 32
SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_STRING


# -----------------------------------------------------------------------------
# Stripe — REQUIRED for billing flows
# -----------------------------------------------------------------------------
# Test keys start with sk_test_ / pk_test_, live keys with sk_live_ / pk_live_.
# Find them at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY

# Stripe webhook signing secret. Used to verify incoming webhook events.
# Get from Stripe Dashboard → Developers → Webhooks → your endpoint →
# Signing secret. Optional — the stripe-replit-sync vendor lib verifies
# upstream as a fallback, but having this set adds local defense-in-depth.
# When set, webhooks failing signature verification are rejected with 400.
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SIGNING_SECRET


# -----------------------------------------------------------------------------
# AWS S3 — REQUIRED for photo uploads
# -----------------------------------------------------------------------------
# IAM user with PutObject/GetObject/DeleteObject on the bucket below.
AWS_ACCESS_KEY_ID=AKIA_REPLACE_WITH_YOUR_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_YOUR_AWS_SECRET
AWS_REGION=us-east-2                          # OPTIONAL — defaults to us-east-2
AWS_S3_BUCKET=fieldview-storage               # OPTIONAL — defaults to fieldview-storage
CLOUDFRONT_DOMAIN=REPLACE_WITH_YOUR_DISTRIBUTION.cloudfront.net  # OPTIONAL — CDN in front of S3


# -----------------------------------------------------------------------------
# Google Maps — REQUIRED for map page + address autocomplete
# -----------------------------------------------------------------------------
# Enable: Maps JavaScript API + Places API. Restrict by HTTP referrer in prod.
GOOGLE_MAPS_API_KEY=AIza_REPLACE_WITH_YOUR_KEY


# -----------------------------------------------------------------------------
# OAuth — OPTIONAL (only set the providers you want enabled)
# -----------------------------------------------------------------------------
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-REPLACE_WITH_YOUR_SECRET

# Microsoft: https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=REPLACE-WITH-YOUR-AZURE-CLIENT-ID
MICROSOFT_CLIENT_SECRET=REPLACE_WITH_YOUR_AZURE_SECRET

# Base URL used to build OAuth callback URLs. Defaults to REPLIT_DOMAINS or
# VERCEL_URL when unset. Set explicitly for custom domains.
OAUTH_BASE_URL=https://app.fieldview.com


# -----------------------------------------------------------------------------
# Email (Resend) — REQUIRED for invitations + password reset
# -----------------------------------------------------------------------------
# Get a key at https://resend.com/api-keys. Verify the sender domain first.
RESEND_API_KEY=re_REPLACE_WITH_YOUR_KEY
EMAIL_FROM=Field View <noreply@fieldview.com>
EMAIL_REPLY_TO=support@fieldview.com
PUBLIC_APP_URL=https://app.fieldview.com    # Used in email links (signup, reset, invites)


# -----------------------------------------------------------------------------
# reCAPTCHA — OPTIONAL (registration spam protection)
# -----------------------------------------------------------------------------
# Register at https://www.google.com/recaptcha/admin (v2 invisible).
# Without these, recaptcha.ts no-ops in dev and rejects in prod.
RECAPTCHA_SECRET_KEY=6L_REPLACE_WITH_YOUR_RECAPTCHA_SECRET
VITE_RECAPTCHA_SITE_KEY=6L_REPLACE_WITH_YOUR_RECAPTCHA_SITE_KEY


# -----------------------------------------------------------------------------
# Sentry — OPTIONAL (frontend error monitoring)
# -----------------------------------------------------------------------------
# Project DSN from https://sentry.io. Without these, Sentry init no-ops.
VITE_SENTRY_DSN=https://REPLACE_WITH_YOUR_SENTRY_KEY@oXXXXXX.ingest.sentry.io/PROJECT_ID
VITE_RELEASE=fieldview@0.1.0


# -----------------------------------------------------------------------------
# Feature flags — OPTIONAL
# -----------------------------------------------------------------------------
# Feature flag: when "true", reads billing state from accounts table
# instead of users table. Default OFF (reads from users). Will be
# flipped to "true" in production after Session 3-5 of the per-account
# billing migration.
ACCOUNT_BILLING_ENABLED=false


# -----------------------------------------------------------------------------
# Runtime — OPTIONAL (sensible defaults)
# -----------------------------------------------------------------------------
NODE_ENV=development          # development | production | test
PORT=5000                     # Local dev port (Vercel/Replit set this automatically)


# -----------------------------------------------------------------------------
# Seed admin passwords — set on first deploy to bootstrap admin accounts
# If unset, seed admins won't be created. Required for fresh deployments only.
# Existing admin users are unaffected by these values.
# -----------------------------------------------------------------------------
SEED_ADMIN_PASSWORD_PRIMARY=REPLACE_WITH_STRONG_PASSWORD
SEED_ADMIN_PASSWORD_SECONDARY=REPLACE_WITH_STRONG_PASSWORD


# -----------------------------------------------------------------------------
# PLATFORM — provided automatically, do NOT set manually
# -----------------------------------------------------------------------------
# Listed here for reference only. Replit/Vercel inject these at runtime.
#
# REPLIT_DOMAINS              # Comma-separated list of Replit hostnames
# REPL_ID                     # Replit workspace ID (read by vite.config.ts)
# REPL_IDENTITY               # Replit identity token (Stripe connector auth)
# REPLIT_DEPLOYMENT           # "1" when running in a Replit deployment
# REPLIT_CONNECTORS_HOSTNAME  # Replit Integrations gateway
# WEB_REPL_RENEWAL            # Replit renewal token (Stripe connector auth)
# VERCEL                      # "1" when running on Vercel
# VERCEL_URL                  # Auto-assigned Vercel preview URL
