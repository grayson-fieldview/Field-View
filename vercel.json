{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.js": {
      "memory": 1769,
      "maxDuration": 60,
      "includeFiles": "dist/public/index.html"
    },
    "api/stripe/webhook.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/stripe/webhook", "destination": "/api/stripe/webhook" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/p/(.*)", "destination": "/api/index" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/max-shift-cleanup",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/ghl-usage-sync",
      "schedule": "0 10 * * *"
    }
  ]
}
